# Reuse the repository-level .env if you prefer. This local file overrides it.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=

# Agent model settings.
HUANGCLAW_CHAT_API_KEY=
HUANGCLAW_CHAT_BASE_URL=
HUANGCLAW_CHAT_MODEL=gpt-4.1-mini
HUANGCLAW_EMBEDDING_API_KEY=
HUANGCLAW_EMBEDDING_BASE_URL=
# If OPENAI_API_BASE_URL points to SiliconFlow, the code defaults to Qwen/Qwen3-Embedding-4B.
# Otherwise it defaults to text-embedding-3-small.
HUANGCLAW_EMBEDDING_MODEL=
# Optional for text-embedding-3-* if you want a smaller vector index.
# HUANGCLAW_EMBEDDING_DIMENSIONS=1024

# Defaults point at ../docs and ./data/chroma.
# HUANGCLAW_DOCS_DIR=../docs
# HUANGCLAW_CHROMA_DIR=./data/chroma
# HUANGCLAW_COLLECTION=learning_robotics_pdf

# Slack Events API.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
